{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "sql:default",
    "sql:allow-execute",
    "fs:default",
    "fs:allow-appdata-read-recursive",
    "fs:allow-appdata-write-recursive",
    "opener:default",
    "deep-link:default",
    "opener:default",
    "fs:default",
    {
      "identifier": "http:default",
      "allow": [{ "url":  "https://www.google.com/favicon.ico" }]
    }
  ]
}
