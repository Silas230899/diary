{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "diary",
  "version": "0.1.0",
  "identifier": "de.hofmann.diary",
  "build": {
    "beforeDevCommand": "npm run start",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist/diary/browser"
  },
  "app": {
    "windows": [
      {
        "title": "diary",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "minSdkVersion": 28
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["diary"]
      },
      "mobile": [
        {
          "scheme": ["diary"],
          "appLink": false,
          "host": ""
        }
      ]
    }
  }
}
